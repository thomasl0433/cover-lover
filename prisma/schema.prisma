// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Band {
  id                 String        @id @default(cuid())
  name               String
  slug               String        @unique
  createdAt          DateTime      @default(now())
  spotifyPlaylistId  String?
  spotifyPlaylistUrl String?
  members            Member[]
  songs              Song[]
  joinRequests       JoinRequest[]
  activities         Activity[]
}

model Member {
  id          String   @id @default(cuid())
  bandId      String
  displayName String
  clerkId     String
  joinedAt    DateTime @default(now())
  band        Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)
  addedSongs  Song[]
  votes       Vote[]

  @@unique([bandId, clerkId])
  @@unique([bandId, displayName])
}

model JoinRequest {
  id          String   @id @default(cuid())
  bandId      String
  clerkId     String
  displayName String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  band        Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@unique([bandId, clerkId])
}

model Song {
  id         String     @id @default(cuid())
  bandId     String
  title      String
  artist     String
  lastfmUrl  String?
  imageUrl   String?
  tags       Json       @default("[]")
  duration   Int?
  spotifyUri String?
  addedById  String?
  addedAt    DateTime   @default(now())
  band       Band       @relation(fields: [bandId], references: [id], onDelete: Cascade)
  addedBy    Member?    @relation(fields: [addedById], references: [id], onDelete: SetNull)
  votes      Vote[]
  activities Activity[]
}

model Vote {
  id       String @id @default(cuid())
  songId   String
  memberId String
  song     Song   @relation(fields: [songId], references: [id], onDelete: Cascade)
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([songId, memberId])
}

model Activity {
  id         String   @id @default(cuid())
  bandId     String
  memberId   String?
  memberName String
  type       String // SONG_ADDED | SONG_REMOVED | VOTED
  songId     String?
  songTitle  String
  songArtist String
  createdAt  DateTime @default(now())
  band       Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)
  song       Song?    @relation(fields: [songId], references: [id], onDelete: SetNull)
}
